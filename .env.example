# qBittorrent connection (QBIT_HOST is required — set to your qBittorrent Web UI URL)
QBIT_HOST=
QBIT_USERNAME=admin
# Required: set to your qBittorrent Web UI password
QBIT_PASSWORD=

# App security — a random key is auto-generated and persisted if not set.
# To set your own:
#   python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# Admin bootstrap (recommended). If omitted, a setup wizard runs on first visit.
ADMIN_USERNAME=admin
# Recommended: set a strong password (8+ chars, mixed case, digit, special)
ADMIN_PASSWORD=

# Set to true if behind an HTTPS reverse proxy
SECURE_COOKIES=false

# Advanced (optional)
# JWT_EXPIRY_MINUTES=720        # Session lifetime in minutes (default: 12 hours)
# LOGIN_RATE_LIMIT=5            # Max login attempts per minute per IP
# TRUSTED_PROXIES=              # Comma-separated trusted proxy IPs for accurate rate limiting
# REFRESH_RATE=5                # Dashboard polling interval in seconds (default: 5, range: 2-300)
#                               # Sets the initial value on first run only; overridden by admin panel

# Browser-accessible qBittorrent URL (optional)
# Set this if QBIT_HOST is a Docker-internal URL the browser can't reach.
# Used for the admin "Open Web UI" button and the opt-in Browser Auth feature.
# Examples: http://localhost:8080, https://qbit.mydomain.com
# QBIT_BROWSER_HOST=

# Browser Auth feature (opt-in, default false)
# When true, the admin panel exposes a form that POSTs qBit credentials from
# the admin's browser to QBIT_BROWSER_HOST to resolve IP bans. This means the
# qBit credentials leave the server — enable only if you accept the trade-off.
# ENABLE_BROWSER_AUTH=false
