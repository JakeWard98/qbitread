# qBittorrent connection
QBIT_HOST=http://localhost:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=changeme

# App security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string

# Admin bootstrap (used on first run to create the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Set to false if not behind HTTPS (e.g. local dev)
SECURE_COOKIES=true
