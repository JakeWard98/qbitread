# qBittorrent connection
QBIT_HOST=http://localhost:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=changeme

# App security — generate a random key using one of the following:
#   Python:      python -c "import secrets; print(secrets.token_hex(32))"
#   PowerShell:  [guid]::NewGuid().ToString("N") + [guid]::NewGuid().ToString("N")
#   OpenSSL:     openssl rand -hex 32
#   Linux:       head -c 32 /dev/urandom | xxd -p
SECRET_KEY=change-me-to-a-random-64-char-string

# Admin bootstrap (used on first run to create the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Set to false if not behind HTTPS (e.g. local dev)
SECURE_COOKIES=true
